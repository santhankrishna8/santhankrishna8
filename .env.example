# ---------------------------------------------------------------------------
# Spotlight environment variables
# Copy this file to ".env.local" and fill in your keys.
# The app runs with realistic sample data even if these are left blank.
# ---------------------------------------------------------------------------

# Google Maps JavaScript API key — used IN THE BROWSER to render the map.
# Restrict it by HTTP referrer in the Google Cloud Console.
# Enable: "Maps JavaScript API".
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Places API key — used ONLY on the server to fetch place data,
# ratings, reviews, and photos. Keep this secret (no NEXT_PUBLIC_ prefix).
# Enable: "Places API (New)". This can be the same project as above,
# ideally a separate key with no referrer restriction (server-side).
GOOGLE_PLACES_API_KEY=

# OpenAI API key — used ONLY on the server for AI suggestions & summaries.
OPENAI_API_KEY=

# Optional: override the OpenAI model (defaults to gpt-4o-mini).
# OPENAI_MODEL=gpt-4o-mini
